{
  "name": "perler-beads",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "next": "15.3.6",
    "next-pwa": "^5.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.3.6",
    "sharp": "^0.34.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.zippland.perlerbeads",
    "productName": "拼豆专业工作台",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["portable"],
      "icon": "public/favicon.ico"
    }
  }
}
